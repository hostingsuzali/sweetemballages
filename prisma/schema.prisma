generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Category {
  id       String    @id
  label    String
  products Product[]

  @@map("categories")
}

model Usage {
  id       String    @id
  label    String
  products Product[] @relation("ProductUsages")

  @@map("usages")
}

model Product {
  id           String   @id
  name         String
  
  categoryId   String   @map("category_id")
  category     Category @relation(fields: [categoryId], references: [id])
  
  dimensions   String
  packaging    String
  price        Float
  priceUnit    String   @map("price_unit")
  customizable Boolean  @default(false)
  minOrderQty  Int?     @map("min_order_qty")
  description  String?
  imageUrl     String?  @map("image_url")
  
  usages       Usage[]  @relation("ProductUsages")

  createdAt    DateTime @default(now()) @map("created_at")

  @@map("produits")
}

model ContactMessage {
  id          String   @id @default(cuid())
  companyName String   @map("company_name")
  email       String
  phone       String?
  message     String
  isRead      Boolean  @default(false) @map("is_read")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("contact_messages")
}

model DemandeDevis {
  id          String   @id @default(cuid())
  companyName String   @map("company_name")
  email       String
  phone       String?
  message     String?
  items       Json?    @map("items")
  isRead      Boolean  @default(false) @map("is_read")
  createdAt   DateTime @default(now()) @map("created_at")
  devis       Devis[]

  @@map("demandes_devis")
}

model ContactInfo {
  id                String  @id @default("default")
  phone             String? @map("phone")
  phoneHours        String? @map("phone_hours")
  email             String? @map("email")
  emailResponseTime String? @map("email_response_time")
  addressLine1      String? @map("address_line1")
  addressLine2      String? @map("address_line2")
  addressCountry    String? @map("address_country")

  @@map("contact_info")
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  passwordHash String         @map("password_hash")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  sessions     AdminSession[]

  @@map("users")
}

model AdminSession {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("admin_sessions")
}

model Facture {
  id             String   @id @default(cuid())
  invoiceNumber  String   @unique @map("invoice_number")
  companyName    String   @map("company_name")
  email          String
  billingAddress String   @map("billing_address")
  issueDate      DateTime @map("issue_date")
  dueDate        DateTime @map("due_date")
  lineItems      Json     @map("line_items")
  notes          String?
  subtotal       Float
  vatRate        Float    @map("vat_rate")
  vatAmount      Float    @map("vat_amount")
  total          Float
  status         String   @default("draft")
  sentAt         DateTime? @map("sent_at")
  createdAt      DateTime @default(now()) @map("created_at")
  devis          Devis?

  @@map("factures")
}

model Devis {
  id                 String        @id @default(cuid())
  devisNumber        String        @unique @map("devis_number")
  demandeDevisId     String?       @map("demande_devis_id")
  demandeDevis       DemandeDevis? @relation(fields: [demandeDevisId], references: [id], onDelete: SetNull)

  companyName        String        @map("company_name")
  email              String
  billingAddress     String?       @map("billing_address")
  issueDate          DateTime      @map("issue_date")
  validUntil         DateTime      @map("valid_until")
  lineItems          Json          @map("line_items")
  notes              String?
  subtotal           Float
  vatRate            Float         @map("vat_rate")
  vatAmount          Float         @map("vat_amount")
  total              Float
  status             String        @default("draft")
  sentAt             DateTime?     @map("sent_at")
  convertedFactureId String?       @unique @map("converted_facture_id")
  convertedFacture   Facture?      @relation(fields: [convertedFactureId], references: [id], onDelete: SetNull)
  createdAt          DateTime      @default(now()) @map("created_at")

  @@map("devis")
}

